{:paths ["src"]
 :aliases {:benchmark {:extra-deps {com.rpl/specter {:mvn/version "1.1.6"}
                                    criterium/criterium {:mvn/version "0.4.6"}}}
           :test-clj {:extra-deps {lambdaisland/kaocha {:mvn/version "1.91.1392"}
                                   lambdaisland/kaocha-junit-xml {:mvn/version "1.17.101"}}
                      :extra-paths ["test"]}
           :test-chrome  {:extra-paths ["test" "cljs-test-runner-out/gen"]
                          :extra-deps  {olical/cljs-test-runner   {:mvn/version "3.8.1" :exclusions [org.clojure/clojurescript]}
                                        org.clojure/clojurescript {:mvn/version "1.12.42"}}
                          :main-opts   ["-m" "cljs-test-runner.main" "-c" "test/cljs-test-opts.edn" "-x" "chrome-headless"]}}}
